{
  "name": "Habit",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Name of the habit"
    },
    "description": {
      "type": "string",
      "description": "Details about the habit"
    },
    "icon": {
      "type": "string",
      "description": "Emoji icon for the habit"
    },
    "category": {
      "type": "string",
      "enum": [
        "health",
        "fitness",
        "mindfulness",
        "learning",
        "productivity",
        "social",
        "creativity",
        "finance",
        "other"
      ],
      "description": "Category of the habit"
    },
    "color": {
      "type": "string",
      "description": "Color hex code for the habit"
    },
    "frequency": {
      "type": "string",
      "enum": [
        "daily",
        "weekly",
        "monthly"
      ],
      "default": "daily",
      "description": "How often the habit repeats"
    },
    "target_value": {
      "type": "number",
      "default": 1,
      "description": "Target count to complete"
    },
    "unit": {
      "type": "string",
      "default": "times",
      "description": "Unit of measurement (cups, pages, minutes, etc.)"
    },
    "reminder_time": {
      "type": "string",
      "description": "Time for reminder in HH:mm format"
    },
    "current_streak": {
      "type": "number",
      "default": 0,
      "description": "Current streak count"
    },
    "best_streak": {
      "type": "number",
      "default": 0,
      "description": "Best streak ever achieved"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "Whether the habit is currently active"
    },
    "sort_order": {
      "type": "number",
      "default": 0,
      "description": "Order of the habit in the list"
    }
  },
  "required": [
    "title",
    "target_value"
  ]
}